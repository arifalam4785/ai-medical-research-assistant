            "timeFrame": "31 months"
          },
          {
            "measure": "Incidence, Nature and Severity of TEAEs, SAEs",
            "description": "Characterization of the safety, tolerability of RMC-4630 in combination with sotorasib for patients with KRASG12C-mutant NSCLC after failure of prior standard therapy. The specifics of the incidence, nature and severity data can be found under the Adverse Events section.",
            "timeFrame": "31 months"
          }
        ]
      },
      "eligibilityModule": {
        "eligibilityCriteria": "Inclusion Criteria:\n\n* Subject must be ≥18 years of age.\n* Subject must have pathologically documented, locally advanced or metastatic KRASG12C NSCLC (not amenable to curative surgery) that has progressed on prior standard therapies (no more than 3 prior lines of therapies are allowed)\n\nExclusion Criteria\n\n* Primary central nervous system (CNS) tumors\n* Known or suspected leptomeningeal or brain metastases or spinal cord compression\n* Clinically significant cardiac disease\n* Known impairment of GI function that would alter the absorption\n* Active autoimmune disease requiring systemic treatment within past 2 years\n* History of severe allergic reactions to any of the study intervention components\n* Major surgical procedures within 28 days or non-study-related minor procedures within 7 days of treatment.\n* Prior therapy with KRASG12C inhibitor and/or SHP2 inhibitor",
        "healthyVolunteers": false,
        "sex": "ALL",
        "minimumAge": "18 Years",
        "stdAges": [
          "ADULT",
          "OLDER_ADULT"
        ]
