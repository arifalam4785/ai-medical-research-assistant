          {
            "type": "PRIMARY",
            "title": "Time on Treatment With Afatinib During Second Line (2L) Treatment Defined by Histology Status",
            "description": "Time on treatment was defined as the interval from the start of second-line treatment until discontinuation of second-line treatment for any reason, e.g. toxicity, progression, death, patient choice. The end of 2L treatment was defined as the date of last treatment order for afatinib plus the days of supply on the last known treatment order up to the date of data collection (but not exceeding). The Kaplan-Meier (KM) method was used to estimate the median and 95% confidence interval for time on treatment. Patients treated with afatinib were analysed for their histology status and categorized into a squamous cell - or mixed histology treatment group.",
            "populationDescription": "All patients (pts) who initiated first-line (1L) pembrolizumab and platinum-based combination chemotherapy (CT) after 1st June 2018, and subsequently discontinued 1L therapy and had started second-line treatment with afatinib at least 3 months prior to date of data collection. Only patients treated with afatinib and with squamous cell - or mixed histology were included in the analysis.",
            "reportingStatus": "POSTED",
            "paramType": "MEDIAN",
            "dispersionType": "95% Confidence Interval",
            "unitOfMeasure": "months",
            "timeFrame": "From the start of second-line treatment until discontinuation of second-line treatment, up to 12.3 months for afatinib treated patients",
            "groups": [
              {
                "id": "OG000",
                "title": "Second-line Afatinib Treatment Group With Squamous Cell Histology",
                "description": "Patients in the second-line afatinib treatment group with squamous cell histology initiated first-line pembrolizumab and platinum-based combination chemotherapy after 1st June 2018, and subsequently discontinued first-line therapy. All patients with squamous cell histology had started second-line treatment with afatinib at least 3 months prior to the date of data collection."
              },
              {
                "id": "OG001",
                "title": "Second-line Afatinib Treatment Group With Mixed Histology",
                "description": "Patients in the second-line afatinib treatment group with mixed histology initiated first-line pembrolizumab and platinum-based combination chemotherapy after 1st June 2018, and subsequently discontinued first-line therapy. All patients with mixed histology had started second-line treatment with afatinib at least 3 months prior to the date of data collection."
              }
            ],
