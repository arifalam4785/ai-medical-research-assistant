          "ADULT",
          "OLDER_ADULT"
        ],
        "studyPopulation": "Patients with metastatic Squamous cell carcinoma (SqCC) of the lung treated with pembrolizumab in combination with platinum doublet chemotherapy as first line (1L) treatment followed by either afatinib as second line (2L) treatment or chemotherapy as 2L treatment.",
        "samplingMethod": "NON_PROBABILITY_SAMPLE"
      },
